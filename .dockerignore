# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include Go module files
!go.mod
!go.sum

# Re-include embedded proxy templates
!internal/controller/proxy_templates/*.yaml

# Re-include embedded SQL migrations and shell scripts
!internal/controller/migrations/*.sql
!internal/controller/scripts/*.sh
